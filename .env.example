# App settings
APP_NAME=SAMHM Backend API
APP_ENV=development
DEBUG=true

# Security / JWT
SECRET_KEY=your_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
TEXT_HASH_SALT=replace_me_with_random_text

# Database
DATABASE_URL=postgresql+psycopg://samhm:samhm_password@localhost:5432/samhm
DB_ECHO=false
DB_AUTO_CREATE=true

# Default seed admin
DEFAULT_ADMIN_EMAIL=admin@samhm.local
DEFAULT_ADMIN_PASSWORD=Admin123!
DEFAULT_ADMIN_NAME=System Administrator
